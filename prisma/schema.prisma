generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProductCategory {
  DECORATIVE_GLASS
  ARCHITECTURAL_GLASS
}

enum PricingType {
  PER_SQFT
  FIXED
}

enum ProductShape {
  RECTANGLE
  SQUARE
  ROUND
  OVAL
}

model Product {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  category      ProductCategory
  description   String
  pricingType   PricingType     @default(PER_SQFT)
  pricePerSqft  Decimal?        @db.Decimal(10, 2)
  fixedPrice    Decimal?        @db.Decimal(10, 2)
  fixedSize     String? // e.g. "24 x 24" for clocks
  shapes        ProductShape[]  @default([RECTANGLE, SQUARE, ROUND, OVAL])
  isFeatured    Boolean         @default(false)
  hasCheckout   Boolean         @default(false)
  isActive      Boolean         @default(true)
  metaTitle     String?
  metaDesc      String?
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  images        ProductImage[]
  colors        ProductColor[]
  orders        Order[]
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model LedColor {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  hexPreview   String? // preview swatch color
  previewImage String?
  description  String?
  extraCharge  Decimal  @default(0) @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  products     ProductColor[]
  orders       Order[]
}

// join table: which colors are available for which product
model ProductColor {
  id        String   @id @default(cuid())
  productId String
  colorId   String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  color     LedColor @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@unique([productId, colorId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY_FOR_DELIVERY
  DELIVERED
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  productId       String
  product         Product     @relation(fields: [productId], references: [id])
  colorId         String?
  color           LedColor?   @relation(fields: [colorId], references: [id])

  shape           ProductShape?
  widthInches     Decimal?    @db.Decimal(10, 2)
  heightInches    Decimal?    @db.Decimal(10, 2)
  isCustomSize    Boolean     @default(false)

  customerName    String
  customerPhone   String
  customerCity    String
  customerAddress String
  notes           String?

  wantsInstallation Boolean   @default(false)

  productCost     Decimal     @db.Decimal(10, 2)
  colorCost       Decimal     @default(0) @db.Decimal(10, 2)
  installationCost Decimal    @default(0) @db.Decimal(10, 2)
  deliveryCost    Decimal     @default(0) @db.Decimal(10, 2)
  totalPrice      Decimal     @db.Decimal(10, 2)

  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model GalleryItem {
  id        String   @id @default(cuid())
  title     String
  category  ProductCategory?
  imageUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

enum InquiryStatus {
  NEW
  CONTACTED
  CLOSED
}

model Inquiry {
  id        String        @id @default(cuid())
  name      String
  phone     String
  email     String?
  city      String?
  message   String
  status    InquiryStatus @default(NEW)
  createdAt DateTime      @default(now())
}

model Settings {
  id                      String  @id @default("settings")
  installationEnabled     Boolean @default(true)
  installationCharge      Decimal @default(0) @db.Decimal(10, 2)
  freeDeliveryThreshold   Decimal @default(0) @db.Decimal(10, 2)
  defaultDeliveryCharge   Decimal @default(0) @db.Decimal(10, 2)
  estimatedProductionDays Int     @default(7)
  estimatedDeliveryDays   Int     @default(3)
  whatsappNumber          String  @default("923015025862")
  ownerEmail              String  @default("mudassirchadhar789@gmail.com")
}

model DeliveryCityRate {
  id     String  @id @default(cuid())
  city   String  @unique
  charge Decimal @db.Decimal(10, 2)
}
